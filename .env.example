# ============================================================
# 基于知识图谱的个性化荐书系统 - 环境配置文件
# ============================================================
# 复制此文件为 .env 并修改相应配置值
#   cp .env.example .env
# ============================================================

# ---------- MySQL 关系型数据库 ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=book_recommend

# ---------- Neo4j 图数据库 ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bookrec2024
NEO4J_DATABASE=bookgraph

# ---------- Redis 缓存 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=bookrec2024

# ---------- Scrapy 爬虫 (scrapy-redis) ----------
SPIDER_REDIS_HOST=localhost
SPIDER_REDIS_PORT=6379
SPIDER_REDIS_PASSWORD=bookrec2024

# ---------- DeepSeek API (Phase 3 使用) ----------
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ---------- 系统配置 ----------
SECRET_KEY=change-me-to-a-random-secret-string
DEBUG=true
LOG_LEVEL=INFO
